<?xml version="1.0"?>
<Container version="2">
  <Name>kids-points-bank</Name>
  <Repository>ghcr.io/robs87/kids-points-bank:latest</Repository>
  <Registry>https://ghcr.io/v2/robs87/kids-points-bank</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Overview>儿童成长积分银行 v2 — 基于代币经济理论的家庭激励工具。前后端分离架构，Flask 后端 + SQLite 数据库 + Nginx 静态前端。支持多账号、多小孩、家长 PIN 码门禁。数据持久化存储在 Unraid 上。</Overview>
  <Category>Tools:</Category>
  <WebUI>http://[IP]:[PORT:8899]/</WebUI>
  <ExtraParams>--restart unless-stopped</ExtraParams>
  <Config Name="Port" Target="80" Default="8899" Mode="tcp"
          Description="WebUI 端口" Type="Port"
          Display="always" Required="true" Mask="false">8899</Config>
  <Config Name="数据目录" Target="/data" Default="/mnt/user/appdata/kids-points-bank/data" Mode="rw"
          Description="SQLite 数据库和媒体文件持久化目录" Type="Path"
          Display="always" Required="true" Mask="false"></Config>
</Container>
